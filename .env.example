# 이 파일을 복사해서 .env 로 만들고, 가진 키 하나만 채우세요 (또는 셸에서 export).
# 둘 다 있으면 --provider 로 고르거나, 기본은 Anthropic 우선으로 자동 선택됩니다.

# Anthropic(Claude) 사용 시 — 발급: https://console.anthropic.com/  -> API Keys
ANTHROPIC_API_KEY=sk-ant-여기에-본인-키

# OpenAI(GPT) 사용 시 — 발급: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-여기에-본인-키
# OPENAI_BASE_URL=            # OpenAI 호환 다른 엔드포인트 쓸 때만 (선택)
